-- [[ OP SCRIPT HUB - CYBER VOID V2 (FIXED VISUALS) ]] --
local player = game.Players.LocalPlayer
local PlayerGui = player:WaitForChild("PlayerGui")
local StarterGui = game:GetService("StarterGui")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")

-- Configuration
local MAX_PRIORITY = 2147483647
local IS_LOADING = true
local LOADING_TIME = 360 -- Magpabilin gihapon og 6 Minutes

local scriptLibrary = {
    "AJJAN SCRIPT", "MANGO HUB", "99LUCK SCRIPT", 
    "DUEL SCRIPT", "DESYNC SCRIPT", "TRADE SCRIPT", 
    "KAWATAN HUB", "INSTA STEAL", "DUPE SCRIPT"
}

StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, false)

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "OP_Script_Hub_V2"
screenGui.ResetOnSpawn = false
screenGui.IgnoreGuiInset = true
screenGui.DisplayOrder = MAX_PRIORITY

local function SecureParent()
    local success, coreGui = pcall(function() return game:GetService("CoreGui") end)
    local target = (success and coreGui) or PlayerGui
    if screenGui.Parent ~= target then screenGui.Parent = target end
end
SecureParent()

