for _, scriptName in pairs(scriptLibrary) do
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 18)
    label.BackgroundTransparency = 1
    label.Text = "[+] " .. scriptName .. " <font color='#00ff00'>STABLE</font>"
    label.TextColor3 = Color3.fromRGB(200, 200, 200)
    label.Font = Enum.Font.Code
    label.RichText = true
    label.TextSize = 14
    label.TextTransparency = 1
    label.ZIndex = 12
    label.Parent = featuresList
    
    task.spawn(function()
        task.wait(math.random(5, 30)) -- Fade in within 30 seconds
        TweenService:Create(label, TweenInfo.new(1.5), {TextTransparency = 0}):Play()
    end)
end

