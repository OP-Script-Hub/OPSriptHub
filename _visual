-- LOGIC & PROTECTION
-----------------------------------------------------------
task.spawn(function()
    while IS_LOADING do
        local msgs = {
            "> Injecting "..scriptLibrary[math.random(1,#scriptLibrary)].."...",
            "> Bypassing Anti-Cheat Logs...",
            "> Loading Cloud Assets...",
            "> Checking Whitelist Status..."
        }
        logLabel.Text = msgs[math.random(1,#msgs)]
        task.wait(math.random(4, 8))
    end
end)

local guardConnection
guardConnection = RunService.RenderStepped:Connect(function()
    if IS_LOADING then
        screenGui.DisplayOrder = MAX_PRIORITY
        SecureParent()
        screenGui.Enabled = true
    else
        guardConnection:Disconnect()
    end
end)

---|| START ||---

local barTween = TweenService:Create(barFill, TweenInfo.new(LOADING_TIME, Enum.EasingStyle.Linear), {Size = UDim2.fromScale(1, 1)})
barTween:Play()

barTween.Completed:Wait()
IS_LOADING = false

-- FADE OUT
for _, v in pairs(screenGui:GetDescendants()) do
    if v:IsA("TextLabel") or v:IsA("Frame") then
        TweenService:Create(v, TweenInfo.new(2), {Transparency = 1}):Play()
    end
end

task.wait(2.2)
screenGui:Destroy()
StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.All, true)
